# ============================================================================
# UPay Gateway - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================================

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GIN_MODE=release  # debug | release | test

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_USER=upay
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=upay_gateway
DB_SSL_MODE=require
DB_MAX_CONNS=25

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Encryption (AES-256 key, generate with: openssl rand -hex 32)
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Security
HMAC_SECRET=CHANGE_ME_HMAC_SECRET
TIMESTAMP_TOLERANCE_SECONDS=300
RATE_LIMIT_PER_MINUTE=60
PAYMENT_SESSION_TTL_MINUTES=15
MAX_TRANSACTIONS_PER_DAY=10000
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=5

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin (first admin user email)
ADMIN_EMAIL=admin@upay.dev
